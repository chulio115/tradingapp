generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CongressTrade {
  id              String   @id @default(cuid())
  chamber         String
  politician      String
  party           String
  state           String?
  ticker          String
  companyName     String?
  transactionType String
  amount          String
  transactionDate DateTime
  filingDate      DateTime
  assetType       String?
  createdAt       DateTime @default(now())

  @@unique([politician, ticker, transactionDate, transactionType])
  @@index([ticker])
  @@index([filingDate])
}

model MarketMover {
  id            String   @id @default(cuid())
  date          DateTime
  ticker        String
  companyName   String
  price         Float
  change        Float
  changePercent Float
  volume        BigInt?
  type          String
  createdAt     DateTime @default(now())

  @@unique([date, ticker, type])
  @@index([date])
}

model NewsCache {
  id          String   @id @default(cuid())
  ticker      String
  title       String
  url         String
  source      String?
  publishedAt DateTime
  summary     String?
  sentiment   Float?
  fetchedAt   DateTime @default(now())

  @@index([ticker, publishedAt])
}

model AlertRule {
  id         String   @id @default(cuid())
  name       String
  type       String
  conditions String
  channel    String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model AlertLog {
  id      String   @id @default(cuid())
  ruleId  String
  message String
  sentAt  DateTime @default(now())
  success Boolean
}
